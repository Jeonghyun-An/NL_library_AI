# ─────────────────────────────────────────────────────────────
# 개발 스택(docker-compose.dev.yml) 환경변수 템플릿
#   - 전부 compose 파일에 기본값이 있어 아무것도 설정 안 해도 기동됨.
#   - 서버에 물리적 .env 파일을 두는 대신, Portainer 스택 등록 화면의
#     "Environment variables" 섹션에 필요한 것만 key=value로 추가할 것
#     (.env는 gitignore 대상이라 Portainer의 git clone에는 포함되지 않음).
#   - vllm/gemma/flux는 운영 스택 것을 공유하므로 여기 없음
#     (HUGGINGFACE_TOKEN 등도 이 스택에서는 불필요).
# ─────────────────────────────────────────────────────────────

POSTGRES_DB_DEV=nl_lib_dev
POSTGRES_USER_DEV=admin
POSTGRES_PASSWORD_DEV=password
MINIO_ACCESS_KEY_DEV=minioadmin
MINIO_SECRET_KEY_DEV=minioadmin

# 스키마 불일치 시 컬렉션 재생성 (기본 false=가드)
MILVUS_RECREATE_ON_MISMATCH_DEV=false

# 인덱스 파라미터 — 운영과 같은 변수명을 공유함 (별도 값 필요하면 여기서 override)
MILVUS_INDEX_TYPE=IVF_FLAT
MILVUS_NLIST=256
MILVUS_NPROBE=32
